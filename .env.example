APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# OpenAI (Ask Hill AI — FAQ + agent RAG)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# Windows/local cURL error 60: download https://curl.se/ca/cacert.pem and set path, e.g. C:\php\extras\ssl\cacert.pem
# OPENAI_CA_BUNDLE=C:\path\to\cacert.pem
# Local dev only if you cannot fix CA bundle (do not use on production):
# OPENAI_VERIFY_SSL=false

# FAQ / AI drawer fetch URLs: same-origin paths vs fixed API origin (local http vs production https)
# true = browser calls /ai/... on the current page origin (default).
# false = prepend FAQ_CHAT_API_ORIGIN (or APP_URL if empty), e.g. http://127.0.0.1:8000 when testing from another host.
FAQ_CHAT_RELATIVE_URLS=true
FAQ_CHAT_API_ORIGIN=
# false = GET /ai/faq-chat returns 405; true = JSON discovery (avoids “405 Method Not Allowed” in the browser)
FAQ_CHAT_ALLOW_GET_DISCOVERY=true
# Ask Hill AI: cap user message length (tokens/cost), idle session + feedback survey, reply length
# FAQ_CHAT_MAX_MESSAGE_CHARS=500
# FAQ_CHAT_MAX_FEEDBACK_COMMENT_CHARS=500
# FAQ_CHAT_IDLE_TIMEOUT_SECONDS=900
# FAQ_CHAT_MAX_REPLY_TOKENS=400

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
